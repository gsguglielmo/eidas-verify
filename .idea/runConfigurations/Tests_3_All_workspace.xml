<component name="ProjectRunConfigurationManager">
  <configuration default="false" name="Tests · 3 · All workspace tests (offline)" type="CargoCommandRunConfiguration" factoryName="Cargo Command">
    <!--
      Runs the entire workspace test suite including DSS / PKITS corpus
      suites. Requires `tools/sync-corpus.sh` to have populated
      tests/vectors/dss-corpus/ and tests/vectors/pkits/. Tests that
      depend on the corpus skip themselves with a logged message when
      the corpus is absent — they do NOT fail the build.
    -->
    <option name="command" value="test --workspace" />
    <option name="workingDirectory" value="file://$PROJECT_DIR$" />
    <envs />
    <option name="emulateTerminal" value="true" />
    <option name="channel" value="DEFAULT" />
    <option name="requiredFeatures" value="true" />
    <option name="allFeatures" value="false" />
    <option name="withSudo" value="false" />
    <option name="buildTarget" value="REMOTE" />
    <option name="backtrace" value="SHORT" />
    <option name="isRedirectInput" value="false" />
    <option name="redirectInputPath" value="" />
    <method v="2">
      <option name="CARGO.BUILD_TASK_PROVIDER" enabled="true" />
    </method>
  </configuration>
</component>
